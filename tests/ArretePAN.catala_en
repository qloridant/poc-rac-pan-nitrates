    -- type_fertilisant: PAN.TypeFertilisant.TypeIII
    -- occupation_sol: PAN.OccupationSol.CINEIntercultureLongueDetruitAnneeSuivante
    -- date_epandage: |2023-09-15|
    -- sol_gele: false
  }
  assertion epandage.epandage_interdit
